# Copia este archivo a `.env.local` y rellena los valores (`.env.local` no se sube a git).

# URL base del API (backend HTTP). El front la lee como VITE_API_URL.
# Sin slash final. Ejemplo local: http://localhost:3000
VITE_API_URL=http://localhost:3000

# PostgreSQL — la usa el **backend** o migraciones / scripts, no el bundle del navegador.
# Formato: postgresql://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_BD
# En Railway: Variables → copia la "Database URL" al entorno del servicio que conecta a la BD.
DATABASE_URL=
